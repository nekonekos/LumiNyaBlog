<!DOCTYPE html>
<html lang="zh">
<head>
  <%- partial('partial/head') %>
</head>
<body>
  <div class="page-wrap">
    <%- partial('partial/header') %>

    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem;">
      <main>
        <% page.posts.each(function(post) { %>
        <article class="post-card glass-card" style="margin-bottom: 1.5rem;">
          <h2 class="post-title"><a href="<%= url_for(post.path) %>" style="color: inherit; text-decoration: none;"><%= post.title %></a></h2>
          <div class="post-meta">
            <i class="fas fa-calendar-alt"></i> <%= date(post.date, 'YYYY-MM-DD') %>
            <% if (post.categories && post.categories.length) { %>
            <i class="fas fa-folder" style="margin-left: 1rem;"></i> <%= post.categories.map(c => c.name).join(', ') %>
            <% } %>
          </div>
          <div class="post-excerpt">
            <%- post.excerpt || post.content.slice(0,200) + '...' %>
          </div>
          <a href="<%= url_for(post.path) %>" class="read-more">阅读全文 <i class="fas fa-arrow-right"></i></a>
        </article>
        <% }) %>

        <% if (page.total > 1) { %>
        <div style="display: flex; gap: 1rem; justify-content: center;">
          <% if (page.prev) { %><a class="read-more" href="<%= url_for(page.prev_link) %>">上一页</a><% } %>
          <% if (page.next) { %><a class="read-more" href="<%= url_for(page.next_link) %>">下一页</a><% } %>
        </div>
        <% } %>
      </main>

      <aside>
        <%- partial('partial/sidebar') %>
      </aside>
    </div>

    <%- partial('partial/footer') %>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>